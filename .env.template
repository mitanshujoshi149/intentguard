# IntentGuard — environment variables
# Copy this to .env and fill in your values

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET
AWS_REGION=us-east-1

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=my-cloudtrail-bucket
S3_PREFIX=AWSLogs/
MAX_FILES=200           # cap downloads to keep memory safe on t2.micro

# ── Pipeline paths ─────────────────────────────────────────────────────────────
LOCAL_LOG_DIR=data/raw
PARSED_CSV=data/parsed_logs.csv
SEQ_LEN=30

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=models/lstm_model.pt
CONFIG_PATH=models/lstm_config.json
